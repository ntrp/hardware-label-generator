{
  "name": "makers-label-generator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "research:assets:audit": "python3 research/catalog-assets/scripts/catalog_assets.py audit",
    "research:assets:steps": "python3 research/catalog-assets/scripts/run_freecad.py generate-fasteners-steps generate --all --threads",
