{
  "name": "standalone-fastener-label-generator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "research:assets:status": "python3 research/catalog-assets/scripts/catalog_assets.py status --write",
    "research:assets:audit": "python3 research/catalog-assets/scripts/catalog_assets.py audit",
    "research:assets:discover": "python3 research/catalog-assets/scripts/catalog_assets.py discover --all",
    "research:assets:render": "python3 research/catalog-assets/scripts/run_freecad.py render --all",
    "research:assets:boltsparts": "python3 research/catalog-assets/scripts/catalog_assets.py boltsparts-sync --write-status",
    "research:assets:boltsparts:generate": "python3 research/catalog-assets/scripts/run_freecad.py boltsparts-generate --all",
    "research:assets:boltsparts:render": "python3 research/catalog-assets/scripts/run_freecad.py boltsparts-generate --all --render",
    "research:assets:fasteners:generate": "python3 research/catalog-assets/scripts/run_freecad.py fasteners-generate --all --threads",
    "research:assets:fasteners:render": "python3 research/catalog-assets/scripts/run_freecad.py fasteners-generate --all --threads --render"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
